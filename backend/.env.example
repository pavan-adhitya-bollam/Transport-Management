# Server Configuration
PORT=5000
NODE_ENV=production

# MongoDB Configuration
# Get your connection string from MongoDB Atlas: https://www.mongodb.com/cloud/atlas
# Format: mongodb+srv://<username>:<password>@cluster.mongodb.net/database
MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/transport-management

# JWT Configuration
# Generate a strong secret key using: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRE=30d

# Frontend URL (for CORS)
# Update this with your deployed frontend URL (e.g., Vercel URL)
FRONTEND_URL=https://your-frontend-domain.vercel.app
